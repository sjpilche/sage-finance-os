# ── Sage Finance OS — Environment Variables ──────────────────
# Copy to .env and fill in real values for your environment.

# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://sage:sage@localhost:5432/sage_finance
DATABASE_URL_SYNC=postgresql://sage:sage@localhost:5432/sage_finance
DB_POOL_MIN=5
DB_POOL_MAX=20

# ── API ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8090
API_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3004

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Sage Intacct ─────────────────────────────────────────────
# Set these per-connection in the UI, or here for single-tenant mode.
SAGE_INTACCT_SENDER_ID=
SAGE_INTACCT_SENDER_PASSWORD=
SAGE_INTACCT_COMPANY_ID=
SAGE_INTACCT_USER_ID=
SAGE_INTACCT_USER_PASSWORD=

# ── Migrations ───────────────────────────────────────────────
RUN_MIGRATIONS=true
